# Backend Configuration
# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Document Ingestion
DATA_DIR=./data
FALLBACK_DIR=.
SUPPORTED_EXTENSIONS=.pdf,.txt,.md,.csv,.json

# Embeddings
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_BATCH_SIZE=16
USE_QUERY_PASSAGE_PREFIX=false
FASTEMBED_CACHE_PATH=./models_cache

# Retrieval
DENSE_TOP_K=12
HYBRID_TOP_K=8
RERANK_TOP_K=5
RRF_K=60
BM25_WEIGHT=0.45
DENSE_WEIGHT=0.55
RERANKER_MODEL=

# Vector Database
QDRANT_LOCAL_PATH=./qdrant_data
QDRANT_COLLECTION_PREFIX=rag

# LLM Configuration (Optional - for better responses)
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=1500

# Azure OpenAI (Alternative)
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_API_TIMEOUT=30000

# Logging
LOG_LEVEL=INFO
